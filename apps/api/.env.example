# Runtime
NODE_ENV=development
PORT=3000

# Frontend origin used for CORS once browser-authenticated routes are enabled.
WEB_ORIGIN=http://localhost:3001

# Database
# Required by the API and Prisma CLI.
DATABASE_URL=postgresql://kinetiq:kinetiq@localhost:5432/kinetiq?schema=public

# Local Docker Compose PostgreSQL service.
POSTGRES_DB=kinetiq
POSTGRES_USER=kinetiq
POSTGRES_PASSWORD=kinetiq
POSTGRES_PORT=5432

# Authentication
# Required when Better Auth is added.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
